---
interface Item { q: string; a: string }
interface Props { items: Item[] }
const { items } = Astro.props;
---
<section class="section" data-reveal>
  <div class="container">
    <p class="badge">FAQ</p>
    <h2 class="section-title">Straight answers before you request a quote.</h2>
    <div class="card" style="padding:1rem 1.2rem;">
      {items.map((item) => (
        <div class="faq-item">
          <details>
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        </div>
      ))}
    </div>
  </div>
</section>
