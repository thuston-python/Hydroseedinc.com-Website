---
import MainLayout from '../../layouts/MainLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import QuoteCTA from '../../components/QuoteCTA.astro';
import { services, locations } from '../../data/site';
import { localBusinessSchema } from '../../data/schemas';
---
<MainLayout title="Services | Hydroseed Inc. Michiana" description="Hydroseeding, lawn installation, erosion control, new construction seeding, and maintenance support in Greater Michiana." schema={localBusinessSchema}>
  <section class="section">
    <div class="container">
      <SectionHeading badge="Services Overview" title="Specialized lawn establishment services for Michiana properties" intro="Every scope starts with project fit: lot size, grade, soil condition, and timeline. Then we match the right approach." />
      <div class="cards-3" style="margin-top:1rem;">
        {services.map((service) => (
          <ServiceCard title={service.title} excerpt={service.excerpt} href={`/services/${service.slug}`} image={service.image} />
        ))}
      </div>
      <article class="card" style="padding:1.2rem;margin-top:1.2rem;">
        <h3>Local service area connections</h3>
        <p>Need location-specific details? Start with your nearest page and request a tailored quote:</p>
        <p style="display:flex;gap:.6rem;flex-wrap:wrap;">
          {locations.slice(0, 5).map((location) => <a class="btn btn-secondary" href={`/locations/${location.slug}`}>{location.name}</a>)}
        </p>
      </article>
    </div>
  </section>
  <QuoteCTA />
</MainLayout>
